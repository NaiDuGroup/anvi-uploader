# PostgreSQL connection string (required)
# Local:    postgresql://printadmin:printadmin@localhost:5432/printupload
# Neon:     postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Cloudflare R2 (required for file uploads)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="print-uploads"
