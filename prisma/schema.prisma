generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String        @id @default(uuid())
  orderNumber  Int           @unique @default(autoincrement()) @map("order_number")
  phone        String
  status       String        @default("NEW")
  assignedTo   String?       @map("assigned_to")
  isWorkshop   Boolean       @default(false) @map("is_workshop")
  isPrio       Boolean       @default(false) @map("is_prio")
  notes        String?
  issueReason  String?       @map("issue_reason")
  createdBy    String?       @map("created_by")
  clientName   String?       @map("client_name")
  publicToken  String        @unique @map("public_token")
  expiresAt    DateTime      @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  files        File[]
  comments     Comment[]
  commentReads CommentRead[]
  creator      User?         @relation("createdOrders", fields: [createdBy], references: [id])

  @@map("orders")
}

model File {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  fileUrl   String  @map("file_url")
  fileName  String  @map("file_name")
  copies    Int     @default(1)
  color     String  @default("bw")
  paperType String? @map("paper_type")
  pageCount Int?    @map("page_count")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("files")
}

model User {
  id            String    @id @default(uuid())
  name          String
  role          String    @default("admin")
  password      String
  sessions      Session[]
  comments      Comment[]
  createdOrders Order[]   @relation("createdOrders")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Comment {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  userId    String   @map("user_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model CommentRead {
  id      String   @id @default(uuid())
  orderId String   @map("order_id")
  userId  String   @map("user_id")
  readAt  DateTime @default(now()) @map("read_at")
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, userId])
  @@map("comment_reads")
}
