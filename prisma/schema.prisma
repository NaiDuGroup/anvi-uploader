generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String        @id @default(uuid())
  orderNumber  Int           @unique @default(autoincrement()) @map("order_number")
  phone        String
  status       String        @default("NEW")
  assignedTo   String?       @map("assigned_to")
  isWorkshop   Boolean       @default(false) @map("is_workshop")
  isPrio       Boolean       @default(false) @map("is_prio")
  price        Int?
  isPaid       Boolean       @default(false) @map("is_paid")
  notes        String?
  issueReason  String?       @map("issue_reason")
  createdBy          String?       @map("created_by")
  sentToWorkshopBy   String?       @map("sent_to_workshop_by")
  clientName         String?       @map("client_name")
  clientId           String?       @map("client_id")
  productType        String        @default("paper_print") @map("product_type")
  mugLayoutData      Json?         @map("mug_layout_data")
  approvalFeedback   String?       @map("approval_feedback")
  publicToken        String        @unique @map("public_token")
  expiresAt          DateTime      @map("expires_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  files              File[]
  comments           Comment[]
  commentReads       CommentRead[]
  logs               OrderLog[]
  creator            User?         @relation("createdOrders", fields: [createdBy], references: [id])
  workshopSender     User?         @relation("sentToWorkshopOrders", fields: [sentToWorkshopBy], references: [id])
  studioClient       StudioCustomer? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@map("orders")
}

// Studio customer registry (table clients). Model name avoids prisma.client delegate ambiguity.
model StudioCustomer {
  id               String   @id @default(uuid())
  kind             String
  phone            String?
  phoneNormalized  String?  @map("phone_normalized")
  personName       String?  @map("person_name")
  companyName      String?  @map("company_name")
  companyIdno      String?  @map("company_idno")
  companyIban      String?  @map("company_iban")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  orders           Order[]

  @@index([phoneNormalized])
  @@map("clients")
}

model File {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  fileUrl   String  @map("file_url")
  fileName  String  @map("file_name")
  copies    Int     @default(1)
  color     String  @default("bw")
  paperType String? @map("paper_type")
  pageCount Int?    @map("page_count")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("files")
}

model User {
  id            String    @id @default(uuid())
  name          String
  role          String    @default("admin")
  password      String
  sessions              Session[]
  comments              Comment[]
  createdOrders         Order[]   @relation("createdOrders")
  sentToWorkshopOrders  Order[]   @relation("sentToWorkshopOrders")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Comment {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  userId    String   @map("user_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model CommentRead {
  id      String   @id @default(uuid())
  orderId String   @map("order_id")
  userId  String   @map("user_id")
  readAt  DateTime @default(now()) @map("read_at")
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, userId])
  @@map("comment_reads")
}

model OrderLog {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  userId    String   @map("user_id")
  action    String
  field     String?
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_logs")
}
